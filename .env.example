# ─── Core ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM Provider ────────────────────────────────────────────────────────────
# "openai" (default) | "anthropic-compat" | "custom"
LLM_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get at: platform.openai.com → API keys
# Required: always needed for Whisper STT, even if LLM_PROVIDER != openai
OPENAI_API_KEY=
# Optional: override default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic (if LLM_PROVIDER=anthropic-compat) ───────────────────────────
# ANTHROPIC_API_KEY=

# ─── Custom provider (if LLM_PROVIDER=custom) ───────────────────────────────
# LLM_BASE_URL=https://your-openai-compatible-endpoint.com/v1
# LLM_API_KEY=

# ─── Landing / Contact ──────────────────────────────────────────────────────
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/your_bot
NEXT_PUBLIC_CONTACT_EMAIL=your@email.com

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get at: t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Max upload size in MB (default: 20)
MAX_UPLOAD_SIZE_MB=20

# ─── Integrations ─────────────────────────────────────────────────────────────

# SmartLMS (Moodle / lms.hse.ru) — optional base URL override
# Default: https://lms.hse.ru/webservice/rest/server.php
# Tokens are per-user and provided at runtime, not here.
# SMARTLMS_BASE_URL=https://lms.hse.ru/webservice/rest/server.php

# YouTube Data API v3 — optional, improves transcript reliability
# Get at: console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
# Without this key, transcripts are fetched via unofficial timedtext endpoint.
# YOUTUBE_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────────────────────

# Sentry — optional error monitoring
# Get at: sentry.io → Create Project → Node.js / Next.js → DSN
# Also requires: npm install @sentry/nextjs
# SENTRY_DSN=

# ─── HSE SSO (Backlog — requires HSE IT cooperation) ──────────────────────────
# Register your app at: it.hse.ru or write to it@hse.ru
# AZURE_CLIENT_ID=       # Azure App Registration Client ID
# AZURE_CLIENT_SECRET=   # Azure App Registration Client Secret
# AZURE_TENANT_ID=hse.ru # HSE Azure AD tenant

# ─── Google Drive (Backlog) ───────────────────────────────────────────────────
# Get at: console.cloud.google.com → OAuth 2.0 Client IDs
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
