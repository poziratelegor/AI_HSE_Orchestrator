# ═══════════════════════════════════════════════════════════════════════════════
# StudyFlow AI — переменные окружения
# Скопируй этот файл в .env.local и заполни. Docker (docker-compose.yml) читает
# именно .env.local, потому что туда же кладётся .env, который не коммитится.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core (ОБЯЗАТЕЛЬНО) ────────────────────────────────────────────────────────
# Публичный URL приложения. Для локального Docker — http://localhost:3000.
# Когда поднимаешь cloudflared для бота — оставь localhost (это для фронта),
# URL туннеля используется только для регистрации Telegram webhook.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (ОБЯЗАТЕЛЬНО) ────────────────────────────────────────────────────
# Создай бесплатный проект на supabase.com → Settings → API.
# Применённые миграции должны включать pgvector (см. supabase/migrations/).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM Provider (ОБЯЗАТЕЛЬНО) ────────────────────────────────────────────────
# "openai" (default) | "anthropic-compat" | "custom"
LLM_PROVIDER=openai

# ── OpenAI (ОБЯЗАТЕЛЬНО) ──────────────────────────────────────────────────────
# Получить: platform.openai.com → API keys
# Нужен всегда (даже если LLM_PROVIDER ≠ openai), потому что Whisper STT (микрофон) использует OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (опционально, если LLM_PROVIDER=anthropic-compat) ──────────────
# ANTHROPIC_API_KEY=

# ── Custom провайдер (опционально, если LLM_PROVIDER=custom) ─────────────────
# LLM_BASE_URL=https://your-openai-compatible-endpoint.com/v1
# LLM_API_KEY=

# ── Telegram (ОБЯЗАТЕЛЬНО только если хочешь бота) ───────────────────────────
# Получить: t.me/BotFather → /newbot
# TELEGRAM_WEBHOOK_SECRET — любая случайная строка длиной 32+ символов,
# используется для верификации входящих webhook'ов от Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── Cloudflare Named Tunnel (опционально, для стабильного URL бота) ──────────
# Без токена — работает quick tunnel (--profile bot, рандомный URL).
# С токеном — named tunnel (--profile bot-named, стабильный URL).
# Получить: dash.cloudflare.com → Zero Trust → Networks → Tunnels →
#   Create a tunnel → Cloudflared → скопируй token из инструкции.
# Затем настрой Public Hostname → service: HTTP → web:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Лендинг / Контакты (опционально) ──────────────────────────────────────────
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/your_bot
NEXT_PUBLIC_CONTACT_EMAIL=your@email.com

# ── Загрузки (опционально) ────────────────────────────────────────────────────
# Максимальный размер загружаемого файла в МБ (по умолчанию 20)
MAX_UPLOAD_SIZE_MB=20

# ── Resend (ОПЦИОНАЛЬНО — отправка email из писем) ───────────────────────────
# Без этого ключа отправка писем из /dashboard/letters работать не будет,
# но генерация и предпросмотр останутся доступны.
# Получить: resend.com → API Keys
RESEND_API_KEY=

# ── Upstash Redis (ОПЦИОНАЛЬНО — rate-limit) ─────────────────────────────────
# Без этих переменных rate-limit работает в "fail-open" (всегда пропускает),
# что приемлемо для демо/локальной разработки.
# Получить: console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (ОПЦИОНАЛЬНО — мониторинг ошибок) ─────────────────────────────────
# Получить: sentry.io → Create Project → Next.js → DSN
SENTRY_DSN=

# ── Интеграции (ОПЦИОНАЛЬНО) ──────────────────────────────────────────────────

# SmartLMS / Moodle HSE — токены подаются per-user в рантайме, не здесь.
# Можно переопределить базовый URL (по умолчанию: https://lms.hse.ru/webservice/rest/server.php)
# SMARTLMS_BASE_URL=

# YouTube Data API v3 — повышает надёжность извлечения транскрипта.
# Без ключа транскрипты тянутся через неофициальный timedtext endpoint.
# YOUTUBE_API_KEY=

# ── HSE SSO (Backlog) ─────────────────────────────────────────────────────────
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=hse.ru

# ── Google Drive (Backlog) ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Cron (Vercel Scheduled Functions) ──────────────────────────────────────────
# Секрет для защиты cron-эндпоинтов (/api/cron/*).
# Vercel Cron автоматически шлёт Authorization: Bearer ${CRON_SECRET}.
# Сгенерируй любую длинную строку (32+ символов).
# CRON_SECRET=
